{
  "name": "cucina-app",
  "private": true,
  "version": "0.10.12",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "build:duemme-pack": "node scripts/build-duemme-pack.mjs",
    "test": "vitest",
    "test:unit": "vitest run",
    "test:watch": "vitest --watch",
    "test:smoke": "vitest run --config vitest.smoke.config.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "prepare": "husky",
    "commit": "cz",
    "lint": "eslint src"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "dependencies": {
    "@vueuse/core": "^14.2.1",
    "dexie": "^4.4.2",
    "lz-string": "^1.5.0",
    "markdown-it": "^14.1.1",
    "pinia": "^3.0.4",
    "qrcode": "^1.5.4",
    "vue": "^3.5.33",
    "vue-router": "^5.0.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitest/ui": "^4.1.5",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^10.2.1",
    "eslint-plugin-vue": "^10.9.0",
    "fake-indexeddb": "^6.2.5",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.4",
    "vue-tsc": "^3.2.7"
  },
  "volta": {
    "node": "22.20.0"
  }
}
